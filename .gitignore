# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# resolved/generated docs
project_documentation.md.resolved
implementation_plan.md.resolved
MINOR_PROJECT_REPORT.md
PROJECT_KNOWLEDGE_BASE.md

# generated reports & outputs (not needed to run the project)
/reports/
/outputs/

# scratch / test scripts
/scratch/
inspect_model.py
test_anomaly.py
test_gemini.js

# python
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# ML model binaries (large files, should not be in git)
backend/models/anomaly/*.pkl
backend/models/emotion/*.pkl
saved_models/
saved_models_goemotion/
backend/saved_models/